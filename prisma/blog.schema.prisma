generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---

enum PostStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum PostVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum SeriesOrderStrategy {
  MANUAL
  BY_DATE
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  FILE
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
  REMOVED
}

enum MenuLocation {
  HEADER
  FOOTER
  SIDEBAR
}

enum RobotsIndex {
  INDEX
  NOINDEX
}

enum RobotsFollow {
  FOLLOW
  NOFOLLOW
}

// --- MODELS ---

model User {
  id             String         @id @default(cuid())
  gamingCenterId String
  username       String         @unique
  email          String         @unique
  password       String
  firstName      String?
  lastName       String?
  profilePicture String?        // URL to OptimizedImageField
  isActive       Boolean        @default(true)
  isStaff        Boolean        @default(false)
  isSuperuser    Boolean        @default(false)
  lastLogin      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  authorProfile  AuthorProfile?
  medias         Media[]        @relation("UploadedBy")
  comments       Comment[]
  reactions      Reaction[]
  revisions      Revision[]     @relation("EditedBy")

  @@map("users_user")
  @@index([gamingCenterId])
}

model AuthorProfile {
  userId         String  @id
  gamingCenterId String
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName    String
  bio            String? @db.Text
  avatarId       String?
  avatar         Media?  @relation("AuthorAvatar", fields: [avatarId], references: [id], onDelete: SetNull)
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  posts       Post[]

  @@map("posts_authorprofile")
  @@index([gamingCenterId])
}

model Category {
  id             String    @id @default(cuid())
  gamingCenterId String
  slug           String
  name           String
  parentId       String?
  parent         Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[] @relation("CategoryHierarchy")
  description    String?   @db.Text
  order          Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts       Post[]

  @@unique([gamingCenterId, slug])
  @@index([slug])
  @@index([gamingCenterId])
  @@map("posts_category")
}

model Tag {
  id             String    @id @default(cuid())
  gamingCenterId String
  slug           String
  name           String
  description    String?   @db.Text
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  posts       PostTag[]

  @@unique([gamingCenterId, slug])
  @@index([slug])
  @@index([gamingCenterId])
  @@map("posts_tag")
}

model Series {
  id             String              @id @default(cuid())
  gamingCenterId String
  slug           String
  title          String
  description    String?             @db.Text
  orderStrategy  SeriesOrderStrategy @default(MANUAL)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  posts         Post[]

  @@unique([gamingCenterId, slug])
  @@index([slug])
  @@index([gamingCenterId])
  @@map("posts_series")
}

model Post {
  id              String         @id @default(cuid())
  gamingCenterId  String
  slug            String
  title           String
  excerpt         String         @db.Text
  isHot           Boolean        @default(false)
  content         String         @db.Text // Restored to String/Text as per rules
  readingTimeSec  Int            @default(0)
  status          PostStatus     @default(DRAFT)
  visibility      PostVisibility @default(PUBLIC)
  publishedAt     DateTime?
  scheduledAt     DateTime?
  viewsCount      Int            @default(0)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  authorId        String
  author          AuthorProfile  @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  categoryId      String?
  category        Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  seriesId        String?
  series          Series?        @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  
  coverMediaId    String?
  coverMedia      Media?         @relation("PostCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  
  ogImageId       String?
  ogImage         Media?         @relation("PostOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)

  // SEO per-post
  seoTitle        String?
  seoDescription  String?        @db.Text
  canonicalUrl    String?
  structuredData  Json?
  robotsIndex     RobotsIndex    @default(INDEX)
  robotsFollow    RobotsFollow   @default(FOLLOW)

  tags            PostTag[]
  revisions       Revision[]
  mediaAttachments PostMedia[]
  comments        Comment[]
  slugHistory     PostSlugHistory[]

  @@unique([gamingCenterId, slug])
  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([gamingCenterId])
  @@map("posts_post")
}

model PostTag {
  postId    String
  tagId     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("posts_posttag")
}

model PostSlugHistory {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  oldSlug   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([oldSlug])
  @@map("posts_postslughistory")
}

model Revision {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  editorId   String?
  editor     User?    @relation("EditedBy", fields: [editorId], references: [id], onDelete: SetNull)
  content    String   @db.Text // Restored to String/Text as per rules
  title      String
  excerpt    String   @db.Text
  changeNote String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("posts_revision")
}

model Media {
  id             String    @id @default(cuid())
  gamingCenterId String
  storageKey     String
  url            String
  type           MediaType
  mime           String
  width          Int?
  height         Int?
  duration       Int?      // in seconds
  sizeBytes      Int       @default(0)
  altText        String?
  title          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  uploadedById   String?
  uploadedBy     User?    @relation("UploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  authorAvatars   AuthorProfile[] @relation("AuthorAvatar")
  postCovers      Post[]          @relation("PostCover")
  postOgImages    Post[]          @relation("PostOgImage")
  postAttachments PostMedia[]

  @@map("medias_media")
  @@index([gamingCenterId])
}

model PostMedia {
  id             String   @id @default(cuid())
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaId        String
  media          Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  attachmentType String   @default("in-content") // e.g., 'in-content', 'cover', 'og-image'
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([postId, mediaId, attachmentType])
  @@map("medias_postmedia")
}

model Comment {
  id             String        @id @default(cuid())
  gamingCenterId String
  postId         String
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId       String?
  parent         Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]     @relation("CommentReplies")
  content        String        @db.Text
  status         CommentStatus @default(PENDING)
  ip             String?
  userAgent      String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("interactions_comment")
  @@index([postId])
  @@index([userId])
  @@index([gamingCenterId])
}

model Reaction {
  id             String   @id @default(cuid())
  gamingCenterId String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reaction       String   // e.g., 'like', or emoji code
  
  // Polymorphic relation simulation (Generic Foreign Key)
  contentType    String   // e.g., 'post', 'comment'
  objectId       String
  
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, contentType, objectId, reaction])
  @@index([contentType, objectId])
  @@index([gamingCenterId])
  @@map("interactions_reaction")
}

model Page {
  id             String     @id @default(cuid())
  gamingCenterId String
  slug           String
  title          String
  content        String     @db.Text // Restored as per rules
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  // SEO per-page
  seoTitle       String?
  seoDescription String?    @db.Text
  canonicalUrl   String?
  structuredData Json?
  robotsIndex    RobotsIndex  @default(INDEX)
  robotsFollow   RobotsFollow @default(FOLLOW)

  sections       PageSection[]
  slugHistory    PageSlugHistory[]

  @@unique([gamingCenterId, slug])
  @@index([slug])
  @@index([gamingCenterId])
  @@map("pages_page")
}

model PageSection {
  id             String   @id @default(cuid())
  pageId         String
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type           String   // e.g., 'HERO', 'RICH_TEXT'
  dataJson       Json     // System policy: Block-based JSON
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([pageId, order])
  @@map("pages_pagesection")
}

model PageSlugHistory {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  oldSlug   String
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
  @@index([oldSlug])
  @@map("pages_pageslughistory")
}

model Menu {
  id             String       @id @default(cuid())
  gamingCenterId String
  name           String
  location       MenuLocation
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  items          MenuItem[]

  @@unique([gamingCenterId, location]) // Fixed to handle multi-tenancy
  @@map("navigation_menu")
  @@index([gamingCenterId])
}

model MenuItem {
  id          String     @id @default(cuid())
  menuId      String
  menu        Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      MenuItem?  @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[] @relation("MenuItemHierarchy")
  label       String
  url         String
  order       Int        @default(0)
  targetBlank Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("navigation_menuitem")
  @@index([menuId, order])
}
