// =======================
// Models
// =======================

model GamingCenter {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)

  // Public identity (site)
  slug        String  @unique
  description String?

  pcCount        Int     @default(0)
  consoleCount   Int     @default(0)
  openingTime    String? // e.g., "09:00"
  closingTime    String? // e.g., "23:00"
  hourlyRate     Float   @default(0)
  vipHourlyRate  Float?
  hasFoodService Boolean @default(false)

  users        User[]
  stations     GameStation[]
  reservations Reservation[]
  shifts       StaffShift[]
  settings     Settings?

  // CRM
  customers CustomerProfile[]

  // Site builder / SEO
  siteSettings SiteSettings?
  pages        Page[]
  media        Media[]
  links        SocialLink[]
  addresses    Address[]

  // Ratings
  ratings Rating[]

  // Commission
  commissionPolicy CommissionPolicy?
  earnings         Earning[]
  auditLogs        AuditLog[]

  // New features
  tournaments Tournament[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  Payment   Payment[]

  @@index([slug])
}

model Settings {
  id String @id @default(cuid())

  gamingCenterId String       @unique
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  preventOverlaps Boolean @default(true)

  timeZone      String?
  workStartTime String?
  workEndTime   String?

  allowOnlineBooking       Boolean @default(false)
  onlineBookingAutoConfirm Boolean @default(false)
  requireOtpForPublicBooking Boolean @default(false)

  maxAdvanceBookingDays    Int   @default(7)
  cancellationHours        Int   @default(2)
  noShowPenaltyAmount      Float @default(0)
  autoReleaseUnpaidMinutes Int   @default(15)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------
// Staff / Panel Users
// -----------------------
model User {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  fullName String
  phone    String

  passwordHash    String?
  phoneVerifiedAt DateTime?

  role String @default("STAFF")
  isActive Boolean  @default(true)

  // Public profile (Team page)
  isPublic   Boolean @default(false)
  publicName String?
  bio        String?
  avatarUrl  String?

  shifts               StaffShift[]
  reservationsAsStaff  Reservation[] @relation("ReservationStaff")
  reservationsCreated  Reservation[] @relation("ReservationCreator")
  canceledReservations Reservation[] @relation("ReservationCanceler")

  // join table (explicit)
  stationSkills StaffStationSkill[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gamingCenterId, phone])
  @@index([gamingCenterId, role])
  @@index([gamingCenterId, isActive])
  @@index([gamingCenterId, isPublic])
}

model Session {
  id String @id @default(cuid())

  actorType String
  actorId   String

  tokenHash String    @unique
  revokedAt DateTime?
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actorType, actorId, expiresAt])
}

// -----------------------
// OTP
// -----------------------
model PhoneOtp {
  id String @id @default(cuid())

  phone   String
  purpose String
  channel String @default("SMS")

  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)

  ip        String?
  userAgent String?

  targetActorType String?
  targetActorId   String?

  createdAt DateTime @default(now())

  @@index([phone, purpose, expiresAt])
  @@index([phone, createdAt])
  @@index([consumedAt])
  @@index([targetActorType, targetActorId])
}

// -----------------------
// Global Customer Identity (cross-center)
// -----------------------
model CustomerAccount {
  id       String  @id @default(cuid())
  phone    String  @unique
  fullName String?

  phoneVerifiedAt DateTime?

  walletBalance Int @default(0)

  profiles           CustomerProfile[]
  reservations       Reservation[]
  ratings            Rating[]
  walletTransactions WalletTransaction[]
  auditLogs          AuditLog[]
  memberships        Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
}

// -----------------------
// Per-center CRM Profile
// -----------------------
model CustomerProfile {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  displayName String?
  note        String?

  reservations Reservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gamingCenterId, customerAccountId])
  @@index([gamingCenterId, displayName])
  @@index([customerAccountId])
  @@index([gamingCenterId, createdAt])
}

// -----------------------
// Game Stations / Shifts
// -----------------------
model GameStation {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  name                 String
  stationType String @default("PC")
  isVip                Boolean         @default(false)
  hourlyPrice          Float
  minRentHours         Int             @default(1)
  maxRentHours         Int             @default(8)
  defaultDurationHours Int             @default(1)
  incrementMinutes     Int             @default(30)
  isActive             Boolean         @default(true)

  reservations Reservation[]
  ratings      Rating[]

  // join table (explicit)
  staffSkills StaffStationSkill[]

  maintenances   StationMaintenance[]
  gamingSessions GamingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, isActive])
  @@index([gamingCenterId, name])
}

model StaffStationSkill {
  userId    String
  stationId String

  skillLevel String @default("BASIC")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  station GameStation @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@id([userId, stationId])
  @@index([stationId])
  @@index([userId])
}

model StaffShift {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dayOfWeek Int
  startTime String
  endTime   String
  shiftRole String @default("HOST")
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gamingCenterId, userId, dayOfWeek])
  @@index([gamingCenterId, dayOfWeek])
}

// -----------------------
// Reservation
// -----------------------
model Reservation {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  customerProfileId String
  customerProfile   CustomerProfile @relation(fields: [customerProfileId], references: [id])

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  stationId String
  station   GameStation @relation(fields: [stationId], references: [id])

  staffId String?
  staff   User?   @relation("ReservationStaff", fields: [staffId], references: [id])

  createdByUserId String
  createdBy       User   @relation("ReservationCreator", fields: [createdByUserId], references: [id])

  startTime DateTime
  endTime   DateTime

  // Snapshot
  stationSnapshot String?

  totalHours     Float
  totalPrice     Float
  discountAmount Float @default(0)
  voucherCode    String?
  paymentState String @default("UNPAID")

  status String @default("CONFIRMED")
  source String @default("WALK_IN")
  note   String?

  canceledAt       DateTime?
  cancelReason     String?
  canceledByUserId String?
  canceledBy       User?     @relation("ReservationCanceler", fields: [canceledByUserId], references: [id])

  completedAt DateTime?
  noShowAt    DateTime?

  payments           Payment[]
  ratings            Rating[]
  earning            Earning?
  walletTransactions WalletTransaction[]
  gamingSessions     GamingSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, startTime])
  @@index([gamingCenterId, staffId, startTime])
  @@index([gamingCenterId, status, startTime])
  @@index([gamingCenterId, staffId, status, startTime, endTime])
  @@index([customerAccountId, startTime])
  @@index([customerProfileId, startTime])
  @@index([gamingCenterId, paymentState, startTime])
}

// -----------------------
// Payments
// -----------------------



model Payment {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id], onDelete: Cascade)

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  amount   Int
  currency String

  provider String @default("MANUAL")
  providerPaymentId  String?
  providerCheckoutId String?
  status String   @default("INITIATED")
  failureReason      String?
  rawProviderPayload String?
  idempotencyKey     String?

  paidAt DateTime?

  method String @default("ONLINE")
  referenceCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique(fields: [provider, providerPaymentId], name: "provider_payment_id")
  @@unique(fields: [gamingCenterId, idempotencyKey], name: "idempotency_key")
  @@index([reservationId, paidAt])
  @@index([status, paidAt])
  @@index([gamingCenterId, status, paidAt])
}

// =====================================================
// Ratings
// =====================================================
model Rating {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  stationId String?
  station   GameStation? @relation(fields: [stationId], references: [id])

  cleanlinessRating Int @default(5)
  equipmentRating   Int @default(5)
  staffRating       Int @default(5)
  priceValueRating  Int @default(5)

  rating  Int
  comment String?

  status String @default("PUBLISHED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reservationId, stationId])
  @@index([gamingCenterId, status, createdAt])
  @@index([stationId, status, createdAt])
  @@index([reservationId])
  @@index([customerAccountId, createdAt])
}

// =====================================================
// Commission
// =====================================================

model CommissionPolicy {
  id String @id @default(cuid())

  gamingCenterId String       @unique
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  type String @default("PERCENT")

  // PERCENT: basis points (e.g., 250 = 2.5%)
  percentBps Int?

  // FIXED
  fixedAmount Int?
  currency    String?

  // Usually only charge commission for ONLINE bookings
  applyToOnlineOnly Boolean @default(true)

  // Optional minimum fee
  minimumFeeAmount Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, isActive])
}

model Earning {
  id String @id @default(cuid())

  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  status String @default("PENDING")

  // base used to calculate commission
  baseAmount Int
  currency   String

  // snapshot of applied policy
  type String
  percentBps  Int?
  fixedAmount Int?

  // final commission amount
  commissionAmount Int

  calculatedAt DateTime?
  chargedAt    DateTime?

  note String?

  payments EarningPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, status, createdAt])
  @@index([chargedAt])
}

model EarningPayment {
  id String @id @default(cuid())

  earningId String
  earning   Earning @relation(fields: [earningId], references: [id], onDelete: Cascade)

  amount   Int
  currency String

  status String  @default("PENDING")
  method String?
  paidAt DateTime?

  referenceCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([earningId, paidAt])
  @@index([status, paidAt])
}

// =====================================================
// Site / Page Builder / SEO
// =====================================================

model SiteSettings {
  id String @id @default(cuid())

  gamingCenterId String       @unique
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  logoUrl    String?
  faviconUrl String?

  defaultSeoTitle       String?
  defaultSeoDescription String?
  defaultOgImageUrl     String?

  googleSiteVerification String?
  analyticsTag           String?

  robotsIndex String  @default("INDEX")
  robotsFollow String @default("FOLLOW")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Page {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  slug  String
  title String
  type String @default("CUSTOM")

  status String @default("DRAFT")
  publishedAt DateTime?

  // SEO per-page
  seoTitle       String?
  seoDescription String?
  canonicalPath  String?
  ogTitle        String?
  ogDescription  String?
  ogImageUrl     String?

  robotsIndex String  @default("INDEX")
  robotsFollow String @default("FOLLOW")

  structuredDataJson String?

  sections    PageSection[]
  slugHistory PageSlugHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gamingCenterId, slug])
  @@index([gamingCenterId, status])
  @@index([gamingCenterId, type])
  @@index([gamingCenterId, publishedAt])
}

model PageSection {
  id String @id @default(cuid())

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  type String
  dataJson String // block config JSON (NO HTML)

  sortOrder Int     @default(0)
  isEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId, sortOrder])
  @@index([pageId, isEnabled])
  @@index([pageId, type])
}

model Media {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  type String    @default("IMAGE")
  purpose String @default("GALLERY")

  url      String
  thumbUrl String?

  // SEO for images
  altText String?

  category String?
  caption  String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, purpose, isActive, sortOrder])
  @@index([gamingCenterId, category])
}

model SocialLink {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  type String
  label String?
  value String

  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId, type])
  @@index([gamingCenterId, isPrimary])
  @@index([gamingCenterId, isActive])
}

// Address (Iran-friendly)
model Address {
  id String @id @default(cuid())

  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  title String?

  province String?
  city     String
  district String?

  addressLine String
  postalCode  String?

  lat Float?
  lng Float?

  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gamingCenterId])
  @@index([gamingCenterId, isPrimary])
  @@index([province])
  @@index([city])
}

model PageSlugHistory {
  id String @id @default(cuid())

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  oldSlug   String
  createdAt DateTime @default(now())

  @@index([pageId, createdAt])
  @@index([oldSlug])
}

// =====================================================
// Analytics Summary Tables
// =====================================================

model GamingCenterAnalytics {
  gamingCenterId String
  date           DateTime

  totalReservations     Int @default(0)
  completedReservations Int @default(0)
  canceledReservations  Int @default(0)
  revenue               Int @default(0)
  realizedCash          Int @default(0)

  peakHours String?
  occupancyRate Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([gamingCenterId, date])
}

model StaffAnalytics {
  gamingCenterId String
  staffId        String
  date           DateTime

  completedReservations Int @default(0)
  revenue               Int @default(0)
  totalRating           Int @default(0)
  ratingCount           Int @default(0)

  reservationsHandled Int   @default(0)
  cancellationRate    Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([gamingCenterId, staffId, date])
}

model StationAnalytics {
  gamingCenterId String
  stationId      String
  date           DateTime

  completedReservations Int @default(0)
  revenue               Int @default(0)

  totalHoursBooked Float @default(0)
  utilizationRate  Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([gamingCenterId, stationId, date])
}

// =====================================================
// Wallet
// =====================================================

model WalletTransaction {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  amount   Int // can be positive (credit) or negative (debit)
  currency String
  type String

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  note String?

  createdAt DateTime @default(now())

  @@index([customerAccountId])
  @@index([reservationId])
}

// =====================================================
// Audit Logging
// =====================================================
model AuditLog {
  id String @id @default(cuid())

  gamingCenterId String?
  gamingCenter   GamingCenter? @relation(fields: [gamingCenterId], references: [id])

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  customerId String?
  customer   CustomerAccount? @relation(fields: [customerId], references: [id])

  action   String // e.g., "RESERVATION_CANCEL", "SETTINGS_UPDATE"
  entity   String // e.g., "Reservation", "Settings"
  entityId String

  oldData String?
  newData String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([gamingCenterId, createdAt])
  @@index([entity, entityId])
  @@index([userId])
}

// =====================================================
// New Gamenet Specific Models
// =====================================================

model GamingSession {
  id            String   @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  stationId String
  station   GameStation @relation(fields: [stationId], references: [id])

  startTime DateTime
  endTime   DateTime?

  actualHours Float               @default(0)
  status String @default("ACTIVE")

  pausedAt      DateTime?
  pausedMinutes Int       @default(0)

  interruptionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StationMaintenance {
  id        String      @id @default(cuid())
  stationId String
  station   GameStation @relation(fields: [stationId], references: [id])

  startTime DateTime
  endTime   DateTime?

  reason String
  cost   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id                String          @id @default(cuid())
  customerAccountId String
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id])

  type      String // e.g. GOLD, SILVER, VIP
  expiresAt DateTime?

  benefits String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tournament {
  id             String       @id @default(cuid())
  gamingCenterId String
  gamingCenter   GamingCenter @relation(fields: [gamingCenterId], references: [id])

  title       String
  description String?
  gameName    String

  startTime DateTime
  endTime   DateTime?

  prizePool       String?
  maxParticipants Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
